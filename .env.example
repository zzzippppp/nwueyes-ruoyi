# 复制为 .env 后按需修改（勿提交 .env）
# Java 进程需自行 export 这些变量，或使用 IDE / systemd / docker-compose 注入

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nwueyes
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# 数据目录（日志抓拍、上传、档案库）
NWUEYES_DATA_DIR=./data
NWUEYES_UPLOAD_PATH=./data/uploadPath
PRESENCE_STORAGE_ROOT=./data
PRESENCE_WORKSPACE_ROOT=./ruoyi
PRESENCE_REPLAY_PROFILE_ROOT=./data/uploadPath

# Python（指向 venv 里的解释器）
PRESENCE_PYTHON=python

# 萤石开放平台 https://open.ys7.com
EZVIZ_APP_KEY=
EZVIZ_APP_SECRET=
EZVIZ_LAN_RTSP_URL=

# Ingest（Python worker 上报 Java 时使用）
PRESENCE_INGEST_ENABLED=true
PRESENCE_INGEST_API_KEY=change-me-ingest-key
PRESENCE_INGEST_BASE_URL=http://localhost:8080

# 生产环境务必修改
TOKEN_SECRET=change-me-jwt-secret
